# Copy to .env.local and fill in (see Supabase Project Settings → API)

# Used to encrypt sensitive platform settings like SMTP and HitPay (AES-256-GCM).
# MUST be at least 32 characters long.
SMTP_SETTINGS_ENCRYPTION_KEY=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Auth: when true, middleware logs + Auth debug panel + browser console (filter DevTools: eventuz:auth). Default: on in dev only.
# NEXT_PUBLIC_AUTH_DEBUG=true
# Optional: log every protected-route middleware hit (noisy). Requires AUTH_DEBUG on.
# NEXT_PUBLIC_AUTH_DEBUG_VERBOSE=true

# Optional: lock attendee view to one published event by public slug (from organizer event settings).
# If unset, the earliest published event is used.
# NEXT_PUBLIC_EVENT_PUBLIC_SLUG=my-wedding-2026

# Base URL for the app (e.g., https://eventuz-iota.vercel.app or http://localhost:3000)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# HitPay checkout (Phase 8) + webhook salt (Dashboard → API Keys / Payment Gateway)
HITPAY_API_KEY=test_1234567890
HITPAY_SANDBOX=true
HITPAY_CURRENCY=PHP
# Required for webhook signature verification (not the same as API key)
HITPAY_SALT=
HITPAY_WEBHOOK_URL=http://localhost:3000/api/hitpay/webhook
# Dev only: simulate HitPay webhook without HitPay (never enable in production)
ALLOW_HITPAY_DEV_SIMULATION=false

# Server-only: payment webhook updates orders/payments (bypass RLS). From Supabase Dashboard → Settings → API.
SUPABASE_SERVICE_ROLE_KEY=
